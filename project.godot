; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DuneVamperium"
run/main_scene="res://game_pieces/board.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Events="*uid://uig3uweaetwy"
Availability="*res://globals/availability.gd"
CardZoom="*res://globals/card_zoom.gd"
SpaceZoom="*res://globals/space_zoom.gd"

[display]

window/size/viewport_width=2400
window/size/viewport_height=1080
window/size/window_width_override=1200
window/size/window_height_override=540
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/PaletteTools/plugin.cfg", "res://addons/Todo_Manager/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
